<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/imgBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/bg_login_cinema"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Dark overlay -->
    <View
        android:id="@+id/overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#77000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="26dp"
            android:gravity="center_horizontal">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CineStack"
                android:textColor="#E7C26C"
                android:textSize="38sp"
                android:textStyle="bold"
                android:layout_marginTop="70dp"/>

            <TextView
                android:id="@+id/tvSubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back!"
                android:textColor="#D9B86A"
                android:textSize="16sp"
                android:layout_marginBottom="38dp"/>

            <!-- Username -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="none"
                android:layout_marginBottom="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_gold"
                    android:hint="Username or Email"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="#E7C26C"
                    android:textColorHint="#D9B86A"
                    android:textCursorDrawable="@drawable/cursor_gold"

                    android:paddingLeft="52dp"
                    android:paddingRight="14dp"

                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawablePadding="14dp"
                    android:drawableTint="#E7C26C"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password (eye toggle) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxBackgroundMode="none"
                app:endIconMode="password_toggle"
                app:endIconTint="#E7C26C"
                android:layout_marginBottom="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_input_gold"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:textColor="#E7C26C"
                    android:textColorHint="#D9B86A"
                    android:textCursorDrawable="@drawable/cursor_gold"

                    android:paddingLeft="52dp"
                    android:paddingRight="52dp"

                    android:drawableStart="@android:drawable/ic_lock_lock"
                    android:drawablePadding="14dp"
                    android:drawableTint="#E7C26C"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Remember me -->
            <CheckBox
                android:id="@+id/cbRememberMe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Remember me"
                android:textColor="#E7C26C"
                android:textSize="14sp"
                app:buttonTint="#E7C26C"
                android:layout_marginBottom="26dp"/>

            <!-- Login button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Login"
                android:textColor="#F5D27B"
                android:textStyle="bold"
                android:textSize="18sp"
                android:background="@drawable/bg_delete_red"
                app:backgroundTint="@null"
                android:stateListAnimator="@null"
                android:layout_marginBottom="22dp"/>

            <!-- Register link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't have an account? "
                    android:textColor="#D9B86A"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Register"
                    android:textColor="#E7C26C"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp"/>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>